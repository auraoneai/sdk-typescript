{
  "name": "@auraone/sdk",
  "version": "0.1.1",
  "type": "module",
  "description": "Official TypeScript SDK for the AuraOne hosted API.",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "dev": "npm run build:watch"
  },
  "keywords": [
    "auraone",
    "api",
    "sdk",
    "typescript",
    "ai",
    "evaluation",
    "training",
    "analytics",
    "collaboration"
  ],
  "author": "AuraOne",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/auraoneai/sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/auraoneai/sdk-typescript/issues"
  },
  "homepage": "https://www.auraone.ai/developers",
  "devDependencies": {
    "langchain": "^0.1.0",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/qs": "^6.14.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "rollup": "^4.5.0",
    "rollup-plugin-dts": "^6.1.0",
    "ts-jest": "^29.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "cross-fetch": "^4.0.0",
    "qs": "^6.11.2"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  }
}
